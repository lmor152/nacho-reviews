# ─── Admin queue ─────────────────────────────────────────────────────────────
# Password used by the /admin page and admin-only API endpoints.
# If unset, the default is `queso`.
ADMIN_PASSWORD=queso

# ─── Database (Firestore) ────────────────────────────────────────────────────
# In production (Cloud Run) Firestore is detected automatically via the
# attached service account — set nothing here. The app reads from the same
# `pending_reviews` and `approved_reviews` collections as the previous
# Streamlit version.
#
# For local development you have a few options:
#
# Option A: inline JSON (good for env-based deploys outside Cloud Run).
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"…","private_key":"…","client_email":"…"}'
#
# Option B: point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON
# file on disk.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#
# Option C: force Firestore on (e.g. when running locally via `gcloud auth
# application-default login`).
# USE_FIRESTORE=true
#
# If none of the above are set, the app falls back to a JSON file at
# `data/reviews.json` (seeded with sample reviews).

# Optional. Override if the SDK can't infer your project from credentials.
# GOOGLE_CLOUD_PROJECT=my-project-id

# Optional. Set if you use a non-default Firestore database.
# FIRESTORE_DATABASE_ID=(default)

# ─── Google Places ───────────────────────────────────────────────────────────
# Used by the submit form to resolve a restaurant name to lat/long. The
# previous version called this `MAPS_API_KEY`; both names are accepted.
# MAPS_API_KEY=your-google-places-api-key
# GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the Next.js server listens on. Cloud Run injects $PORT automatically;
# locally the dev server uses 3000 by default.
# PORT=8080
